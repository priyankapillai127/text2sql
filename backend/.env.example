# ── App ──────────────────────────────────────────────
APP_NAME=Text2SQL Backend
APP_VERSION=1.0.0
DEBUG=true

# ── Database ─────────────────────────────────────────
# SQLite path used for Spider/CoSQL sample databases
SQLITE_DB_DIR=./data/databases

# ── Ollama (local open-source LLM) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Proprietary frontier model (OpenAI / Gemini) ─────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── RAG / Embeddings ─────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_DIR=./data/faiss_index
SPIDER_EXAMPLES_PATH=./data/spider_train.json
RAG_TOP_K=3

# ── SQL Repair ───────────────────────────────────────
MAX_REPAIR_ATTEMPTS=2
